    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/svd-clean.de/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/svd-clean.de/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

server {
    server_name musterfirma.svd-clean.de;

    client_max_body_size 25m;

    location / {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 60s;
    }

    listen [::]:443 ssl; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/svd-clean.de/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/svd-clean.de/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}


server {
    if ($host = www.svd-clean.de) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = svd-clean.de) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;
    server_name svd-clean.de www.svd-clean.de;
    return 404; # managed by Certbot




}

server {
    if ($host = app.svd-clean.de) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;
    server_name app.svd-clean.de;
    return 404; # managed by Certbot


}

server {
    if ($host = demo.svd-clean.de) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;
    server_name demo.svd-clean.de;
    return 404; # managed by Certbot


}

server {
    if ($host = musterfirma.svd-clean.de) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;
    server_name musterfirma.svd-clean.de;
    return 404; # managed by Certbot


}